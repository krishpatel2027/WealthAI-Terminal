# WealthAI Hackathon Production Environment Template

# 1. Anthropic API Key (Required for AI Brain / Claude 3)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 2. Google Gemini API Key (Required for Vector Embeddings in RAG)
# Get one at: https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# 3. Supabase Configuration (Required for persistence)
# Get this from your Supabase Dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here

# 4. Redis Configuration (Required for fast Vitals Caching)
# Note: Use upstash.com for a free cloud Redis URL.
REDIS_URL=redis://localhost:6379/0

# 5. Frontend URL (Used for CORS Security Policies)
# Defaults to wildcard for local dev, ensure you set it to your deployed Render/Vercel URL later.
FRONTEND_URL=*
